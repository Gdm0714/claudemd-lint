{
  "name": "claudemd-lint",
  "version": "1.4.3",
  "description": "Smart CLAUDE.md manager — auto-detect corrections, suggest rules, deduplicate, and track effectiveness",
  "type": "module",
  "scripts": {
    "build": "tsc && node scripts/build-mcp-server.mjs",
    "build:types": "tsc",
    "build:mcp": "node scripts/build-mcp-server.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "claude-code",
    "plugin",
    "claude-md",
    "automation",
    "rules-management"
  ],
  "author": {
    "name": "claudemd-lint contributors"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
